{
  "manifest_version": 3,
  "name": "Ref Watch",
  "version": "0.2.0",
  "description": "Quick poll on controversial referee calls.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ref Watch"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://*.supabase.co/*"]
}
